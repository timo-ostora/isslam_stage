created:
    - database/factories/CategoryFactory.php
    - database/factories/CourseFactory.php
    - database/factories/EnrollmentFactory.php
    - database/factories/ModuleFactory.php
    - database/factories/ModuleItemFactory.php
    - database/factories/LessonFactory.php
    - database/factories/AssessmentFactory.php
    - database/migrations/2026_06_15_184223_create_categories_table.php
    - database/migrations/2026_06_15_184224_create_courses_table.php
    - database/migrations/2026_06_15_184225_create_enrollments_table.php
    - database/migrations/2026_06_15_184226_create_modules_table.php
    - database/migrations/2026_06_15_184227_create_module_items_table.php
    - database/migrations/2026_06_15_184228_create_lessons_table.php
    - database/migrations/2026_06_15_184229_create_assessments_table.php
    - database/migrations/2026_06_15_184230_create_enrollment_user_table.php
    - database/migrations/2026_06_15_184231_create_course_enrollment_table.php
    - app/Models/Category.php
    - app/Models/Course.php
    - app/Models/Enrollment.php
    - app/Models/Module.php
    - app/Models/ModuleItem.php
    - app/Models/Lesson.php
    - app/Models/Assessment.php
models:
    User: { name: string, email: string, email_verified_at: 'datetime nullable', password: string, remember_token: 'string nullable', two_factor_secret: 'text nullable', two_factor_recovery_codes: 'text nullable', two_factor_confirmed_at: 'datetime nullable' }
    Category: { parent_id: 'id foreign:categories nullable', title: 'string unique', description: 'text nullable', timestamps: timestamps, relationships: { hasMany: 'Course, Category:children', belongsTo: 'Category:parent' } }
    Course: { slug: 'string unique', category_id: 'id foreign:categories', creator_id: 'id foreign:users', title: string, description: string, thumbnail_url: 'string nullable', status: 'enum:draft,published,archived default:draft', difficulty_level: 'enum:easy,medium,hard', language: 'string default:en', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: 'Category, User:creator', hasMany: 'Module, Enrollment, Certificate, User' } }
    Enrollment: { user_id: 'id foreign:users', course_id: 'id foreign:courses', status: 'enum:active,completed,cancelled default:active', progress_percentage: 'decimal:5,2 default:0', completed_at: 'timestamp nullable', timestamps: timestamps, softdeletes: softDeletes, indexes: [{ unique: 'user_id, course_id' }, { index: 'user_id, status' }], relationships: { belongsToMany: 'User, Course' } }
    Module: { course_id: 'id foreign:courses', title: string, order_index: 'unsignedInteger default:0', description: 'text nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { belongsTo: Course, hasMany: ModuleItem } }
    ModuleItem: { module_id: 'id foreign:modules', position: integer, timestamps: true, relationships: { belongsTo: Module, morphTo: itemable } }
    Lesson: { title: string, description: 'string nullable', type: 'enum:video,article,pdf,link', content_url: 'string nullable', content_text: 'text nullable', metadata: 'json nullable', duration_seconds: 'unsignedInteger default:0', timestamps: timestamps, softdeletes: softDeletes, relationships: { morphMany: ModuleItem, hasMany: LessonProgress } }
    Assessment: { title: string, description: 'string nullable', type: 'enum:quiz,exam,assignment', duration_seconds: 'unsignedInteger nullable', passing_score: 'unsignedInteger default:50', max_attempts: 'unsignedInteger nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { morphMany: ModuleItem, hasMany: 'Question, Attempt' } }
